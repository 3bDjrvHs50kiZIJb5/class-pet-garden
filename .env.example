# MySQL（docker compose 使用）
MYSQL_ROOT_PASSWORD=classpets
MYSQL_DATABASE=classpets

# 应用数据库连接
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=classpets
DB_NAME=classpets
DB_CONNECTION_LIMIT=10

# 应用端口
APP_PORT=3002
PORT=3002

# 认证限流（同一 IP）
AUTH_RATE_LIMIT_ENABLED=true
AUTH_REGISTER_RATE_LIMIT_MAX=1
AUTH_REGISTER_RATE_LIMIT_WINDOW_MS=3600000
AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=60000

# 安全（生产环境务必修改）
TOKEN_SECRET=请替换为随机长字符串
ADMIN_DEFAULT_PASSWORD=请替换为强密码
